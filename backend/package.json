{
  "scripts": {
    "condition:run-jobner-v1": "node condition/condition_analysis_job_runner_v1.mjs",
    "condition:worker": "node condition/condition_analysis_job_runner_v1.mjs",
    "condition:worker:once": "node condition/condition_analysis_job_runner_v1.mjs --once --max-jobs 1",
    "pricing:scheduler": "node pricing/pricing_scheduler_v1.mjs",
    "pricing:worker": "node pricing/pricing_job_runner_v1.mjs",
    "pricing:worker:once": "node pricing/pricing_job_runner_v1.mjs --once --max-jobs 1",
    "pricing:queue:experimental": "node pricing/pricing_queue_worker.mjs",
    "scanner:identity:v3": "node identity_v3/run_scanner_v3_identity_service_v1.mjs",
    "scanner:identity:v3:full-db:coverage": "node identity_v3/build_scanner_v3_full_db_identity_index_v1.mjs --coverage-only",
    "scanner:identity:v3:full-db:sample": "node identity_v3/build_scanner_v3_full_db_identity_index_v1.mjs --build-index --limit 20",
    "scanner:identity:v3:latency": "node identity_v3/run_scanner_v3_identity_latency_harness_v1.mjs",
    "scanner:identity:v3:ann:build": "node identity_v3/build_scanner_v3_ann_index_v1.mjs",
    "scanner:identity:v3:ann:serve": "node identity_v3/run_scanner_v3_ann_identity_service_v1.mjs",
    "scanner:fixed-slot:regression": "node identity_v3/run_fixed_slot_artifact_regression_v1.mjs",
    "scanner:identity:v5": "cd .. && node backend/identity_v3/scanner_v5/run_scanner_v5_identity_service_v1.mjs --artifact-dir backend/identity_v3/scanner_v5/fixtures/artifact --debug-dir .tmp/scanner_v5_identity_service",
    "scanner:identity:v5:regression": "cd .. && node backend/identity_v3/scanner_v5/run_scanner_v5_regression_v1.mjs --cases backend/identity_v3/scanner_v5/scanner_v5_regression_cases_v1.json --artifact-dir backend/identity_v3/scanner_v5/fixtures/artifact --out .tmp/scanner_v5_regression_v1/latest.json",
    "scanner:identity:v5:augment-trial": "cd .. && node backend/identity_v3/scanner_v5/build_augmented_index_v1.mjs --artifact-dir .tmp/scanner_v3_ann_index_v1/full_candidate_compact_v1 --out .tmp/scanner_v5_augmented_trial_200 --limit 200"
  },
  "dependencies": {
