NODE_ENV=production
DOTENV_CONFIG_PATH=/etc/grookai/scanner-v3-identity.env

SCANNER_V3_IDENTITY_HOST=127.0.0.1
SCANNER_V3_IDENTITY_PORT=8787
SCANNER_V3_IDENTITY_TOP_K=50
SCANNER_V3_IDENTITY_MODEL=Xenova/clip-vit-base-patch32
SCANNER_V3_IDENTITY_INDEX_CACHE=/opt/grookai-scanner-identity/data/scanner_v3_embedding_index_v7_plus_me_sets_v1.json
SCANNER_V3_IDENTITY_FALLBACK_INDEX_CACHE=/opt/grookai-scanner-identity/data/scanner_v3_embedding_index_v7_plus_me_sets_v1.json

TRANSFORMERS_CACHE=/opt/grookai-scanner-identity/hf-cache
HF_HOME=/opt/grookai-scanner-identity/hf-cache
