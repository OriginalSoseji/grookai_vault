SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Backend-only secret (do not send to Edge Functions or clients)
SUPABASE_SECRET_KEY=sb_secret_...

# Bridge token for protected Edge Function routes
BRIDGE_IMPORT_TOKEN=...

# Optional Edge middleware abuse protection.
# When both Upstash values are set in Vercel, registry/API/search rate limits
# use durable Redis counters across edge instances. Without them, middleware
# falls back to best-effort in-memory counters.
UPSTASH_REDIS_REST_URL=https://<database>.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
GROOKAI_RATE_LIMIT_REDIS_PREFIX=gv:rate-limit:v1

# Web-only key for the short-lived encrypted Binder invitation handoff cookie.
# Generate at least 32 random characters; never prefix this variable with NEXT_PUBLIC_.
BINDER_INVITE_TRANSIENT_SECRET=replace-with-at-least-32-random-characters

# Collaborative Binder web rollout gates. Keep every gate false until its
# corresponding database migration, contract fixture, and staged acceptance
# checkpoint have passed. Later gates also fail closed when a prerequisite is
# disabled; see COLLABORATIVE_BINDERS_SYSTEM_CONTRACT_V1.md.
GROOKAI_BINDERS_SCHEMA_RPC_V1_ENABLED=false
GROOKAI_BINDERS_PERSONAL_V1_ENABLED=false
GROOKAI_BINDERS_SHARED_V1_ENABLED=false
GROOKAI_BINDERS_VIEW_LINKS_V1_ENABLED=false
GROOKAI_BINDERS_PUBLIC_V1_ENABLED=false
GROOKAI_BINDERS_COMMUNITY_V1_ENABLED=false
GROOKAI_BINDERS_TEMPLATES_V1_ENABLED=false
GROOKAI_BINDERS_NOTIFICATIONS_V1_ENABLED=false
GROOKAI_BINDERS_PULSE_SHARING_V1_ENABLED=false
GROOKAI_BINDERS_SET_V1_ENABLED=false
GROOKAI_BINDERS_CUSTOM_V1_ENABLED=false

# Pokemon API (backend workers only; optional key is sent as X-Api-Key when present)
POKEMONAPI_BASE_URL=https://api.pokemontcg.io/v2
POKEMONAPI_API_KEY=YOUR_POKEMONAPI_KEY_HERE

# TCGdex REST API (official base URL + language)
TCGDEX_BASE_URL=https://api.tcgdex.net/v2

# Active language for TCGdex API (en, fr, es, es-mx, it, pt, pt-br, pt-pt, de, n)
TCGDEX_LANG=en

# No API key is required according to official TCGdex documentation
TCGDEX_API_KEY=

# eBay Integration (pricing, inventory, analytics)
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
EBAY_REDIRECT_URI="" # e.g., https://localhost:3000/ebay/oauth/callback
EBAY_ENV="production" # 'production' or 'sandbox'
EBAY_MARKETPLACE_ID="EBAY_US" # default marketplace for our account

# PSA Public API (server-side slab verification)
PSA_API_BASE_URL=https://api.psacard.com/publicapi
PSA_API_TOKEN=""

# Browse API (active listings)
EBAY_BROWSE_BASE_URL=https://api.ebay.com/buy/browse/v1
# Use `npm run ebay:browse:token` to fetch a short-lived token and paste it here (never commit secrets).
EBAY_BROWSE_ACCESS_TOKEN=""
