# Copy to /etc/grookai/mee-nightly.env on the droplet.

NODE_ENV=production
MEE_NIGHTLY_ALLOW_RUN=1
# Provider calls stay disabled unless explicitly enabled.
MEE_NIGHTLY_PROVIDER_CALLS_ENABLED=0
MEE_NIGHTLY_NORMALIZATION_ONLY=0
MEE_NIGHTLY_MAX_CALL_CEILING=4000
# Caps nightly free-reference acquisition targets such as TCGCSV.
MEE_NIGHTLY_REFERENCE_LIMIT=5000

SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=

# Use either a pre-issued Browse token or eBay OAuth client credentials.
EBAY_BROWSE_ACCESS_TOKEN=
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_BROWSE_BASE_URL=https://api.ebay.com/buy/browse/v1
# EBAY_OAUTH_BASE_URL=https://api.ebay.com/identity/v1

# Optional override used by deployment wrapper scripts.
MEE_NIGHTLY_CALL_CEILING=4000
