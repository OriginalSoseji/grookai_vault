# Copy to /etc/grookai/mee-nightly.env on the droplet.

NODE_ENV=production
MEE_NIGHTLY_ALLOW_RUN=1

SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Use either a pre-issued Browse token or eBay OAuth client credentials.
EBAY_BROWSE_ACCESS_TOKEN=
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_BROWSE_BASE_URL=https://api.ebay.com/buy/browse/v1
# EBAY_OAUTH_BASE_URL=https://api.ebay.com/identity/v1

# Optional override used by deployment wrapper scripts.
MEE_NIGHTLY_CALL_CEILING=4000

# Post-ingest orchestration runs after acquisition. It does not need eBay auth.
MEE_POST_INGEST_ALLOW_RUN=1
MEE_POST_INGEST_ALLOW_INTERNAL_WRITES=0
MEE_POST_INGEST_ALLOW_DERIVED_REFRESH=1
MEE_POST_INGEST_MODE=plan_then_apply_internal
MEE_POST_INGEST_MAX_LIFECYCLE_OBSERVATIONS=10000
MEE_POST_INGEST_MAX_CLEANUP_EVENTS=60000
# Leave disabled unless the host has Supabase CLI login configured.
MEE_POST_INGEST_ENABLE_LEGACY_LIFECYCLE_PLAN=0
