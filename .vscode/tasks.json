{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GV: Validate import-prices (apikey-only)",
      "type": "shell",
      "command": "pwsh -File scripts/session_sync_bridge_and_validate.ps1",
      "problemMatcher": []
    },
    {
      "label": "GV: Align until proofs (LOOP)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-File", "scripts/ci/align_until_proofs.ps1"],
      "problemMatcher": []
    },
    {
      "label": "GV: Migration Audit (Strict)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "scripts/migration_preflight_strict.ps1",
        "-Phase",
        "AuditLinkedSchema"
      ],
      "problemMatcher": []
    },
    {
      "label": "GV: Migration PrePush (Strict)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "scripts/migration_preflight_strict.ps1",
        "-Phase",
        "PrePush",
        "-ExpectedLocalOnlyIds",
        "${input:gvExpectedLocalOnlyIds}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "gvExpectedLocalOnlyIds",
      "type": "promptString",
      "description": "Comma-separated expected local-only migration IDs",
      "default": ""
    }
  ]
}
