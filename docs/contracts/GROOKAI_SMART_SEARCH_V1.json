      "visible_interpreted_filters",
      "search_explainability",
      "english_physical_card_search",
      "governed_special_case_identity_family_search"
    ],
    "out_of_scope": [
      "db_writes",
      "migrations",
      "canonical_identity_changes",
      "vault_mutations",
      "pricing_mutations",
      "mobile_app_implementation",
      "ai_generated_sql",
      "ai_model_calls_on_normal_search_execution_path",
      "multilingual_expansion"
    ]
  },
