{
  "contract_key": "GROOKAI_SMART_SEARCH_V1",
  "status": "active",
  "date": "2026-06-17",
  "objective": "Build app-like search result presentation plus governed natural-language search that compiles into safe structured filters without replacing normal search with AI.",
  "db_writes_allowed": false,
