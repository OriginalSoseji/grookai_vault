{
  "contract_key": "GROOKAI_SMART_SEARCH_V1",
  "status": "proposed",
  "date": "2026-06-17",
  "objective": "Build app-like search result presentation plus governed natural-language search that compiles into safe structured filters.",
  "db_writes_allowed": false,
  "migrations_allowed": false,
  "arbitrary_sql_allowed": false,
  "scope": {
    "in_scope": [
      "web_search_result_hierarchy",
      "structured_filter_model",
      "natural_language_query_parsing",
      "visible_interpreted_filters",
      "search_explainability",
      "english_physical_card_search"
    ],
    "out_of_scope": [
      "db_writes",
      "migrations",
      "canonical_identity_changes",
      "vault_mutations",
      "pricing_mutations",
      "mobile_app_implementation",
      "ai_generated_sql",
      "multilingual_expansion"
    ]
  },
  "allowed_filters_v1": [
    "text",
    "species",
    "set_codes",
    "set_names",
    "finish_keys",
    "variant_keys",
    "stamp_labels",
    "rarities",
    "release_year_min",
    "release_year_max",
    "owned_state",
    "image_state",
    "artist",
    "domain",
    "sort"
  ],
  "required_examples": [
    "all reverse holo Pikachu cards from 2014 to 2026",
    "give me every Gengar",
    "all first edition Charizards",
    "cards with Build-A-Bear stamps",
    "all cosmos holo promos from Sword and Shield",
    "every card I own from Evolving Skies",
    "missing Pikachu cards in my vault",
    "all cards with no exact image",
    "all stamped variants from Toys R Us",
    "all cards illustrated by Ken Sugimori"
  ],
  "implementation_phases": [
    "result_card_hierarchy",
    "structured_filter_model",
    "deterministic_phrase_parser",
    "search_explainability_ui",
    "expanded_enrichment_search"
  ],
  "safety_rules": [
    "natural_language_must_compile_to_typed_filters",
    "unsupported_terms_must_be_reported",
    "no_inferred_finishes",
    "no_inferred_variants",
    "no_guessed_stamps",
    "no_mutation_side_effects"
  ]
}
