  "source_artifacts": [
    "docs/audits/printing_truth_v1/printing_truth_global_audit_v1.json",
    "docs/audits/printing_truth_v1/unsupported_printings_v1.json",
    "docs/audits/printing_truth_v1/reverse_holo_integrity_v1.json"
  ],
  "rollback": [
    "stop sidecar writers",
    "drop public.v_card_printing_truth_current_v1",
    "drop public.card_printing_truth_reviews",
    "drop public.set_card_printing_truth_reviews_updated_at_v1"
  ]
