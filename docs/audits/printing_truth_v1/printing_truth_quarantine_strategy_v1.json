{
  "version": "PRINTING_TRUTH_QUARANTINE_STRATEGY_V1",
  "date": "2026-05-23",
  "phase": "phase_2_quarantine_strategy",
  "destructive": false,
  "canonical_mutations": {
    "card_printings": false,
    "vault": false,
    "ownership": false,
    "provenance": false,
    "pricing": false,
